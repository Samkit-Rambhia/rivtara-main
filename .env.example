# Local development
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Required in ALL environments (local + Vercel)
# Use MongoDB Atlas for production: https://www.mongodb.com/atlas
MONGO_URI=mongodb://localhost:27017/rivtara

# Use a long, random string in production (e.g. `openssl rand -hex 64`)
JWT_SECRET=rivtara_jwt_secret_change_in_production
JWT_EXPIRE=30d
